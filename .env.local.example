# Required.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Models per role — defaults live in lib/server/models.ts (DEFAULT_MODELS).
# Set any of these to override per role; OPENROUTER_MODEL overrides all text
# roles at once. The per-app picker in the UI wins over both.
# OPENROUTER_BACKEND_MODEL=
# OPENROUTER_DESIGN_MODEL=
# OPENROUTER_FRONTEND_MODEL=
# OPENROUTER_IMAGE_GEN_MODEL=
# OPENROUTER_MODEL=
# OPENROUTER_MAX_RETRIES=4

# Optional — Langfuse tracing (disabled when absent).
LANGFUSE_SECRET_KEY=""
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"
