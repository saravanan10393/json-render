# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local

# OpenRouter API key — create one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Model the builder agent uses (any OpenRouter model id).
# Defaults to anthropic/claude-sonnet-4.5 when unset.
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5

# Optional — Langfuse observability (https://cloud.langfuse.com → project settings).
# When set, every agent run is traced (LLM calls, tool calls, latency, usage).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
